{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/rianorie/filament-excel-import.git"
        }
    ],
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.1",
        "bepsvpt/secure-headers": "^9.1",
        "bezhansalleh/filament-shield": "^4.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "hayderhatem/filament-excel-import": "dev-main#33ebca0d54cdb3d1ecc0b59111733274be176220 as 4.1.0",
        "kirschbaum-development/eloquent-power-joins": "^4.3",
        "lab404/laravel-impersonate": "^1.7",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^13.0",
        "laravel/pulse": "^1.7",
        "laravel/scout": "^11.2",
        "laravel/tinker": "^3.0",
        "laravolt/avatar": "^6.4",
        "maatwebsite/excel": "^3.1",
        "opcodesio/log-viewer": "^3.24",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/eloquent-sortable": "^5.0",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-csp": "^3.25",
        "spatie/laravel-health": "^1.39",
        "spatie/laravel-honeypot": "^4.7",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-model-states": "^2.14",
        "spatie/laravel-permission": "^7.0",
        "spatie/laravel-schemaless-attributes": "^2.6",
        "spatie/laravel-tags": "^4.11",
        "staudenmeir/eloquent-has-many-deep": "^1.22"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.1",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": {
                "PKSA-3d8r-4bff-vcj1": "CVE-2026-48761 symfony/html-sanitizer — patch (8.0.13) not yet on Packagist; remove when symfony/symfony releases the next 8.0.x.",
                "PKSA-bvdf-tk8n-sbsf": "CVE-2026-48760 symfony/html-sanitizer — patch (8.0.13) not yet on Packagist; remove when symfony/symfony releases the next 8.0.x.",
                "PKSA-y6py-qpv1-h52p": "CVE-2026-48736 symfony/http-foundation — patch (8.0.13) not yet on Packagist; remove when symfony/symfony releases the next 8.0.x.",
                "PKSA-bf7t-jnpz-492k": "CVE-2026-48784 symfony/routing — patch (8.0.13) not yet on Packagist; remove when symfony/symfony releases the next 8.0.x."
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
