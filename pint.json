{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": false,
        "ordered_class_elements": {
            "order": [
                "use_trait",
                "constant_public",
                "constant_protected",
                "constant_private",
                "property_public",
                "property_protected",
                "property_private",
                "construct",
                "destruct",
                "method_public",
                "method_protected",
                "method_private"
            ]
        },
        "phpdoc_align": {
            "align": "left"
        },
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "method_argument_space": {
            "on_multiline": "ensure_fully_multiline"
        },
        "blank_line_before_statement": {
            "statements": [
                "return",
                "throw",
                "try"
            ]
        },
        "concat_space": {
            "spacing": "one"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor"
    ],
    "notPath": [
        "_ide_helper.php",
        "_ide_helper_models.php"
    ]
}
