# Semgrep ignore — vendored / generated assets that aren't our source.
# Anything Filament publishes via `php artisan filament:assets` lives in
# public/js/filament/ — we don't write or maintain those files, scanning
# them produces noise (8+ false positives in minified Chart.js, slider,
# file-upload).

# Filament published JS/CSS assets (php artisan filament:assets)
public/js/filament/**
public/css/filament/**

# Vite build output (generated by `npm run build`)
public/build/**

# Symfony Mailer + other vendor-shipped public assets
public/vendor/**

# Composer-installed dependencies
vendor/**

# Node modules (usually never committed, but excluded just in case)
node_modules/**

# Pre-existing baselines (e.g. phpstan baseline JSON)
phpstan-baseline.neon

# Storage / cache / temporary files
storage/**
bootstrap/cache/**
